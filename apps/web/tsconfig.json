{
  "extends": ["../../tsconfig.base.json", "astro/tsconfigs/strict"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@design/*": ["./src/design/*"],
      "@map/*": ["./src/map/*"],
      "@dashboard/*": ["./src/dashboard/*"],
      "@main/*": ["./src/main/*"],
      "@live/*": ["./src/live/*"],
      "@replay/*": ["./src/replay/*"]
    },
    "types": ["@astrojs/cloudflare", "@cloudflare/workers-types"]
  },
  "include": [
    "src/**/*",
    "functions/**/*",
    ".astro/types.d.ts",
    "astro.config.mjs",
    "tailwind.config.ts",
    "playwright.config.ts"
  ],
  "exclude": ["dist", "node_modules", "playwright-report", "test-results"]
}
