---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Logo } from '../design/Logo';

// Plan v2.3 §1.1: every shell prerenders. The main page is fully static; React islands
// (Hero countdown, GP grid, etc.) hydrate client-side only when implementer lands them in Phase 3.
export const prerender = true;
---

<BaseLayout
  title="SOON BOARD — Unofficial F1 fan dashboard"
  description="Live timing, replay, and season catalog for Formula 1 fans. Powered by OpenF1. Non-commercial, attribution required."
>
  <section class="hero">
    <Logo client:visible size={96} />
    <h1 class="sr-only">SOON BOARD</h1>
    <p class="tagline">Unofficial F1 fan dashboard.</p>
    <p class="status">
      <span class="status-badge">PRE-ALPHA</span>
      Phase 3 will replace this placeholder with the season catalog (see
      <a href="/.omc/plans/main-page-implementation.md">main-page-implementation.md</a>).
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding: 64px 32px;
    min-height: calc(100dvh - 200px);
    text-align: center;
  }

  .tagline {
    margin: 0;
    font-size: 18px;
    color: var(--color-text-secondary);
  }

  .status {
    margin: 0;
    font-size: 13px;
    color: var(--color-text-tertiary);
    max-width: 480px;
    line-height: 1.6;
  }

  .status-badge {
    display: inline-block;
    padding: 2px 8px;
    margin-right: 8px;
    background: var(--color-accent);
    color: var(--color-text-primary);
    font-family: 'JetBrains Mono', monospace;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    border-radius: 2px;
    vertical-align: middle;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
