---
import BaseLayout from '../../layouts/BaseLayout.astro';

/**
 * Live screen shell.
 *
 * Plan v2.3 §1.1 — shell prerenders to static HTML at build time. The actual
 * LiveScreen React island is mounted client-only and consumes Pages Function
 * `/api/live/:endpoint` for live data (Phase 2 + 5 land the implementation).
 *
 * `getStaticPaths` with `fallback: 'all'` keeps this dynamic route prerender-eligible
 * for arbitrary session_keys: Astro emits a single shell that 404s on unknown keys.
 */
export const prerender = true;

export function getStaticPaths() {
  // Plan §10 follow-up — we don't know all session_keys at build time. Return a single
  // placeholder so Astro can emit the static shell; the React island handles real
  // routing at runtime by reading Astro.params.session_key on hydration.
  return [{ params: { session_key: 'placeholder' } }];
}

const { session_key } = Astro.params;
---

<BaseLayout
  title={`LIVE — ${session_key} · SOON BOARD`}
  description={`Live F1 session ${session_key} on SOON BOARD. 30s-delayed broadcast mirror.`}
>
  <section class="live-shell">
    <header class="header">
      <h1>LIVE · {session_key}</h1>
      <p class="placeholder-note">
        React island will mount here in Phase 5. Until then this shell renders the static layout
        with attribution + meta.
      </p>
    </header>
    <div class="island-mount" data-session-key={session_key}>
      {/* <LiveScreen client:only="react" sessionKey={session_key} /> */}
    </div>
  </section>
</BaseLayout>

<style>
  .live-shell {
    display: flex;
    flex-direction: column;
    min-height: calc(100dvh - 200px);
  }

  .header {
    padding: 24px 32px;
    border-bottom: 1px solid var(--color-bg-border);
  }

  .header h1 {
    margin: 0;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .placeholder-note {
    margin: 8px 0 0;
    color: var(--color-text-tertiary);
    font-size: 13px;
  }

  .island-mount {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px;
    color: var(--color-text-secondary);
  }
</style>
