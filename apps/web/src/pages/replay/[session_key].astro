---
import BaseLayout from '../../layouts/BaseLayout.astro';

/**
 * Replay screen shell.
 *
 * Plan v2.3 §1.1 — shell prerenders to static HTML. ReplayScreen React island will
 * mount client-only in Phase 5; it fetches historical OpenF1 data DIRECTLY from
 * api.openf1.org (no Pages Function involvement — historical is anonymous + free).
 */
export const prerender = true;

export function getStaticPaths() {
  return [{ params: { session_key: 'placeholder' } }];
}

const { session_key } = Astro.params;
---

<BaseLayout
  title={`REPLAY — ${session_key} · SOON BOARD`}
  description={`Replay of F1 session ${session_key} on SOON BOARD. Historical data via OpenF1, no live delay.`}
>
  <section class="replay-shell">
    <header class="header">
      <h1>REPLAY · {session_key}</h1>
      <p class="placeholder-note">
        React island (ReplayScreen + LiveMap) will mount here in Phase 5.
      </p>
    </header>
    <div class="island-mount" data-session-key={session_key}>
      {/* <ReplayScreen client:only="react" sessionKey={session_key} /> */}
    </div>
  </section>
</BaseLayout>

<style>
  .replay-shell {
    display: flex;
    flex-direction: column;
    min-height: calc(100dvh - 200px);
  }

  .header {
    padding: 24px 32px;
    border-bottom: 1px solid var(--color-bg-border);
  }

  .header h1 {
    margin: 0;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .placeholder-note {
    margin: 8px 0 0;
    color: var(--color-text-tertiary);
    font-size: 13px;
  }

  .island-mount {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px;
    color: var(--color-text-secondary);
  }
</style>
