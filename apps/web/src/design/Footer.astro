---
/**
 * Attribution footer applied to every page.
 * Plan AC-24: visible attribution + unofficial disclaimer on every route.
 */
---

<footer class="soonboard-footer">
  <p class="line">
    <span>Data:&nbsp;</span>
    <a
      href="https://openf1.org/"
      target="_blank"
      rel="noopener noreferrer"
    >OpenF1 (CC BY-NC-SA 4.0)</a>
    <span class="sep">·</span>
    <span>Tracks:&nbsp;</span>
    <a
      href="https://github.com/julesr0y/f1-circuits-svg"
      target="_blank"
      rel="noopener noreferrer"
    >julesr0y/f1-circuits-svg (CC BY 4.0)</a>
  </p>
  <p class="line line-disclaimer">
    Unofficial fan project — not affiliated with Formula 1, FIA, or FOM.
  </p>
</footer>

<style>
  .soonboard-footer {
    padding: 24px 32px;
    border-top: 1px solid var(--color-bg-border);
    color: var(--color-text-tertiary);
    font-size: 11px;
    line-height: 1.6;
    text-align: center;
  }

  .line {
    margin: 0;
  }

  .line-disclaimer {
    margin-top: 4px;
    color: var(--color-text-tertiary);
  }

  .sep {
    margin: 0 6px;
    color: var(--color-bg-border);
  }

  a {
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-decoration-color: var(--color-bg-border);
    text-underline-offset: 2px;
  }

  a:hover {
    color: var(--color-text-primary);
  }
</style>
