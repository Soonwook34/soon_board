{
  "name": "soon-board",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint: placeholder for Phase 0 (ESLint config not yet wired)\"",
    "test": "vitest run --passWithNoTests",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --reporter=list --grep-invert=@long",
    "e2e:long": "playwright test --grep=@long",
    "fetch:catalog": "tsx scripts/fetch-season-catalog.ts --all",
    "fetch:catalog:year": "tsx scripts/fetch-season-catalog.ts",
    "fetch:race-distance": "echo \"fetch:race-distance: scripts/fetch-race-distance.ts not yet implemented\"",
    "fetch:maps": "tsx scripts/fetch-circuit-maps.ts",
    "fetch:transform": "tsx scripts/extract-openf1-transform.ts",
    "trace:pitlane": "tsx scripts/trace-pitlane.ts",
    "derive:sectors": "tsx scripts/derive-sector-boundaries.ts",
    "derive:drs": "tsx scripts/derive-drs-zones.ts",
    "load:slm": "tsx scripts/load-slm-zones.ts",
    "build:all": "tsx scripts/build-all-circuits.ts",
    "build:all:base": "tsx scripts/build-all-circuits.ts --skip-sectors --skip-drs --skip-slm",
    "build:catalog": "tsx scripts/build-circuits-catalog.ts",
    "curate:residual": "tsx scripts/curate-residual.ts",
    "refresh-data": "npm run fetch:catalog && npm run fetch:race-distance && npm run fetch:maps",
    "check:season-sizes": "tsx scripts/check-season-sizes.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "svg-path-properties": "^2.0.2",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
